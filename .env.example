# ----------------------------------------------------------------------------
# Business Card Scanner — environment template
# Copy to ".env" for local dev. On Netlify, add these under
# Site settings -> Environment variables. Never commit real secrets.
# ----------------------------------------------------------------------------

# --- App ---
# Public base URL of the deployment (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# --- PostgreSQL (use a pooled connection on serverless: Neon / Supabase) ---
# Pooled URL for the app (PgBouncer/Neon pooler). Used at runtime.
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct (non-pooled) URL. Used only by Prisma migrations.
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# --- Google OAuth + People (Contacts) API ---
# Create at https://console.cloud.google.com -> APIs & Services -> Credentials.
# Authorised redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# Enable the "People API" for the project.
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# --- AI provider ---
# Which provider to use for extraction: "anthropic" | "openai" | "gemini"
AI_PROVIDER="anthropic"
# Set the model your account has access to.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"

# --- Object storage (S3-compatible: Cloudflare R2 or AWS S3) ---
# For R2: endpoint is https://<accountid>.r2.cloudflarestorage.com and region "auto".
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="business-cards"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional: public base URL if the bucket serves images publicly (e.g. R2 public dev URL).
# Leave blank to serve images through the app's signed-URL route instead.
S3_PUBLIC_BASE_URL=""

# --- Limits ---
# Max card scans allowed per user per hour.
RATE_LIMIT_SCANS_PER_HOUR="60"
